# Copy this file to .env and fill in what you need.

# Optional: only needed if you want to use "OpenRouter" mode in Saro AI.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which model OpenRouter should use. Browse free options at
# https://openrouter.ai/models?max_price=0 and swap this if you like.
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Local LLM settings (Ollama). Ollama must be installed and running:
# https://ollama.com/download
# Then pull a small model, e.g.:  ollama pull phi3:mini
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini
